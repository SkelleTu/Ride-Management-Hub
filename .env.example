# ============================================================
# Environment variables required for Vercel deployment
# Copy these to your Vercel project's Environment Variables
# ============================================================

# PostgreSQL connection string (use Neon free tier: https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your_random_secret_here_at_least_32_chars

# ============================================================
# Development only (Replit sets these automatically)
# ============================================================
PORT=8080
BASE_PATH=/
